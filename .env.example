# Public frontend configuration.
# Production defaults to same-origin /api when this is omitted.
# Set this only when the frontend and API are deployed on different origins.
VITE_API_BASE_URL=https://api.example.com/api
# Public profile URL shown in the UI.
VITE_PUBLIC_APP_URL=https://flowlinks.org

# Server configuration.
NODE_ENV=development
PORT=8787
JWT_SECRET=replace-with-a-long-random-secret
DATA_DIR=./data
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
APP_URL=http://127.0.0.1:8787
# Public API origin used in verification email links. Keep equal to APP_URL for same-origin deploys.
API_PUBLIC_URL=http://127.0.0.1:8787
# Comma-separated emails allowed to open /admin after signing in.
ADMIN_EMAILS=admin@example.com
# Local frontend fallback only. The server-side ADMIN_EMAILS setting is authoritative in production.
VITE_ADMIN_EMAILS=admin@example.com

# SMTP email verification.
# In development, if SMTP_HOST is empty, verification links are printed to the server console.
# Production requires a real sender with SPF, DKIM, and DMARC configured for the MAIL_FROM domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=LinkFlow
EMAIL_VERIFICATION_TTL_HOURS=24

# OAuth provider credentials.
# Google sign-in uses a real server-side OAuth redirect flow.
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/api/oauth/google/callback

APPLE_OAUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
APPLE_REDIRECT_URI=http://127.0.0.1:8787/api/oauth/apple/callback

# Optional future integrations.
OPENAI_API_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
