# LinkFlow production environment

# Server
NODE_ENV=production
PORT=8787
APP_URL=https://flowlinks.org
# Public API origin used in verification email links. Same-origin deploys can keep this equal to APP_URL.
API_PUBLIC_URL=https://flowlinks.org
DATA_DIR=/var/www/linkflow/shared/data
CORS_ORIGIN=https://flowlinks.org,https://www.flowlinks.org

# Security
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Frontend API
# Same-origin production deploy should keep this empty or /api.
VITE_API_BASE_URL=/api

# SMTP email verification
# Use a transactional provider/domain that has SPF, DKIM, and DMARC enabled.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_WITH_SMTP_USERNAME
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
MAIL_FROM=no-reply@flowlinks.org
MAIL_FROM_NAME=LinkFlow
EMAIL_VERIFICATION_TTL_HOURS=24

# OAuth.
# Google sign-in uses a real server-side OAuth redirect flow.
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://flowlinks.org/api/oauth/google/callback

APPLE_OAUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/var/www/linkflow/shared/AuthKey_XXXXXXXXXX.p8
APPLE_REDIRECT_URI=https://flowlinks.org/api/oauth/apple/callback

# Optional future providers/integrations
OPENAI_API_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
